# =============================================================================
# Unreal Engine .gitignore
# Excludes auto-generated, cache, and build artifact directories.
# Keep this file under version control.
# =============================================================================

# Generated by Unreal — never commit
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Generated for plugins too
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Visual Studio / Rider IDE
.vs/
.vscode/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.user

# Generated solution / project files (regenerated by UE)
*.xcodeproj/
*.xcworkspace/

# Mac / Linux
.DS_Store
*.swp
*~

# Unreal local user settings
*.uprojectdirs

# Crash reports / logs
Crashes/
*.log
*.dmp

# Personal backups
*.zip
*.7z
*.rar
*.bak

# Misc
node_modules/
*.tmp
